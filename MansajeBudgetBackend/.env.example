# ─────────────────────────────────────────────────────────────
# MansajeBudget Backend — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Allowed CORS origins (comma-separated). Use * for development only.
ALLOWED_ORIGINS=*

# ── Plaid ─────────────────────────────────────────────────────
# Get these from https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_secret

# Options: sandbox | development | production
PLAID_ENV=sandbox

# Webhook URL (must be publicly reachable, e.g. via ngrok during development)
# Example: https://abc123.ngrok.io/webhooks/plaid
PLAID_WEBHOOK_URL=https://your-backend.example.com/webhooks/plaid

# Plaid webhook signature verification (ES256 JWT).
# Set to 'false' ONLY when testing locally with a tunnel (ngrok, etc.) and
# Plaid sandbox webhooks cannot be verified end-to-end.
# THIS FLAG IS BLOCKED IN PRODUCTION — setting it to 'false' there causes a 500.
PLAID_VERIFY_WEBHOOKS=true

# ── Supabase ───────────────────────────────────────────────────
# Get from Supabase Dashboard → Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# NEVER expose SUPABASE_SERVICE_ROLE_KEY client-side

# ── Anthropic AI (for /v1/insights/monthly) ───────────────────
# Get from https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key
